# Server root URL (no /api/v1 suffix)
# For local dev:  http://127.0.0.1:8000
# For api3:       https://api3.powerfrill.com
API_ROOT_URL=https://api3.powerfrill.com

# Optional: full API base (overrides API_ROOT_URL + API_VERSION_PATH)
# API_BASE_URL=https://api3.powerfrill.com/api/v1

# Optional: version prefix used when API_BASE_URL is not provided.
# API_VERSION_PATH=/api/v1

# Required for Supabase password login + token refresh.
# Example:
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=
SUPABASE_ANON_KEY=

APP_ENV=production
